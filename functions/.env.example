# Email Configuration for Firebase Cloud Functions
# Copy this file to .env and fill in your email service credentials

# Gmail SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Your email credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# From email address
EMAIL_FROM=noreply@growi.app

# To enable Gmail App Passwords:
# 1. Go to https://myaccount.google.com/
# 2. Click "Security" in the left navigation
# 3. Enable "2-Step Verification" if not already enabled
# 4. Under "App passwords", select "Mail" and "Windows Computer" (or your platform)
# 5. Copy the generated password and paste it here

# Alternative: SendGrid Configuration
# Uncomment these lines if you prefer SendGrid
# EMAIL_SERVICE=SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@growi.app
